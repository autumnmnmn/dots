#!/bin/bash

AGENT_HOME="/data/2/agents"

AGENT_SANDBOX_PROGRAMS=(python)

AGENT_SANDBOX_ENV=(
    PYTHON_HISTORY=/dev/null
)

agent="$1"
program="$2"
shift 2

# ========  Validate Params  ======== #

allowed=false
for entry in "${AGENT_SANDBOX_PROGRAMS[@]}"; do
	[[ "$entry" == "$program" ]] && allowed=true && break
done

if ! $allowed; then
        echo "error: program '$program' is not in the whitelist" >&2
        return 1
fi

if ! id "$agent" &>/dev/null; then
        echo "error: user '$agent' does not exist" >&2
        return 1
fi

if ! id -nG "$agent" | grep -qw "sandbox-access"; then
        echo "error: user '$agent' is not in the sandbox-access group" >&2
        return 1
fi

# ========  Set up environment  ======== #

setenv_flags=()
for env_var in "${AGENT_SANDBOX_ENV[@]}"; do
	setenv_flags+=(--setenv="$env_var")
done

# ========  Run  ======== #

sudo systemd-run --quiet --uid="$agent" --pipe --wait \
        "${setenv_flags[@]}" \
        --working-directory="$AGENT_HOME/$agent" \
        --property=SupplementaryGroups=sandbox-access \
        --property=TemporaryFileSystem=/data:ro \
        --property=InaccessiblePaths=/ssd \
        --property=InaccessiblePaths=/home \
        --property=PrivateNetwork=true \
        --property=PrivateTmp=true \
        --property=RemoveIPC=true \
        --property=ProtectSystem=strict \
        --property=ProtectHome=true \
        --property=PrivateDevices=true \
        --property=BindPaths="$AGENT_HOME/$agent" \
        --property=NoNewPrivileges=true \
        --property=CapabilityBoundingSet= \
        --property=MemoryMax=32G \
        --property=CPUQuota=20% \
        --property=TasksMax=32 \
        --property=PrivateUsers=true \
        --property=ProtectProc=invisible \
        --property=ProcSubset=pid \
        --property=ProtectKernelTunables=true \
        --property=ProtectKernelModules=true \
        --property=ProtectControlGroups=true \
        --property=SystemCallFilter=@system-service \
        --property=SystemCallErrorNumber=EPERM \
        --property=RestrictAddressFamilies=AF_UNIX \
        --property=LockPersonality=true \
        --property=RestrictRealtime=true \
        --property=LimitNOFILE=4096 \
        "$program" "$@"


